# Flutter / Dart
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
build/
*.g.dart

# Riverpod generated files that should be committed are *.g.dart inside lib/
# Override: track generated provider files
!lib/**/*.g.dart

# pubspec.lock — commit for apps, ignore for packages
# (kept for reproducible builds)

# Firebase — never commit
google-services.json
GoogleService-Info.plist

# Android build artefacts
*.iml
.gradle/
/local.properties
local.properties
/captures/
.externalNativeBuild/
.cxx/
android/local.properties

# iOS build artefacts
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec

# IntelliJ / Android Studio / VS Code
/.idea/caches/
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml
.vscode/
*.orig

# macOS
.DS_Store

# Notes
notes/

# Keystore — never commit signing keys
*.jks
*.keystore
keystore.properties
